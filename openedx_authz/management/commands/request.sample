# ===== PLATFORM ADMINISTRATORS =====

# Alice - Platform admin (global scope) - should have access to everything
user:alice, act:manage, *, True
user:alice, act:manage, lib:math-basics, True
user:alice, act:manage, org:OpenedX, True
user:alice, act:manage, course:course-v1:OpenedX+DemoX+CS101, True
user:alice, act:edit, lib:any-library, True
user:alice, act:read, lib:any-library, True
user:alice, act:write, lib:any-library, True
user:alice, act:delete, lib:any-library, True


# ===== ORGANIZATION ADMINISTRATORS =====

# Bob - OpenedX org admin (should have access within OpenedX scope)
user:bob, act:manage, org:OpenedX, True
user:bob, act:edit, org:OpenedX, True
user:bob, act:read, org:OpenedX, True
user:bob, act:write, org:OpenedX, True
user:bob, act:delete, org:OpenedX, True

# Bob - Cross-org access (should be denied - no role in other orgs)
user:bob, act:manage, org:MIT, False
user:bob, act:read, org:MIT, False
user:bob, act:edit, org:MIT, False

# Bob - Global access (should be denied - not platform admin)
user:bob, act:manage, *, False

# Bob - Exception case: cannot delete specific course (deny rule)
user:bob, act:delete, course:course-v1:OpenedX+DemoX+CS101, False


# ===== ORGANIZATION EDITORS =====

# Eve - OpenedX org editor (should have edit access within OpenedX scope)
user:eve, act:edit, org:OpenedX, True
user:eve, act:read, org:OpenedX, True
user:eve, act:write, org:OpenedX, True

# Eve - Should NOT have manage/delete permissions (only editors, not admin)
user:eve, act:manage, org:OpenedX, False
user:eve, act:delete, org:OpenedX, False

# Eve - Cross-org access (should be denied - no role in other orgs)
user:eve, act:edit, org:MIT, False
user:eve, act:read, org:MIT, False

# Eve - Global access (should be denied - not platform admin)
user:eve, act:edit, *, False
user:eve, act:manage, *, False

# Eve - Course access (should be denied - no role in course scope)
user:eve, act:edit, course:course-v1:OpenedX+DemoX+CS101, False
user:eve, act:manage, course:course-v1:OpenedX+DemoX+CS101, False


# ===== COURSE INSTRUCTORS =====

# Carol - Course instructor for CS101 (should have access within course scope)
user:carol, act:manage, course:course-v1:OpenedX+DemoX+CS101, True
user:carol, act:edit, course:course-v1:OpenedX+DemoX+CS101, True
user:carol, act:read, course:course-v1:OpenedX+DemoX+CS101, True
user:carol, act:write, course:course-v1:OpenedX+DemoX+CS101, True
user:carol, act:delete, course:course-v1:OpenedX+DemoX+CS101, True

# Carol - Cross-course access (should be denied)
user:carol, act:manage, course:course-v1:MIT+PHYS101+2025, False
user:carol, act:edit, course:course-v1:OpenedX+Math101+2025, False

# Carol - Cross-scope access (should be denied)
user:carol, act:manage, org:OpenedX, False
user:carol, act:manage, lib:math-basics, False


# ===== LIBRARY REVIEWERS =====

# David - math-basics library reviewer (read-only access)
user:david, act:read, lib:math-basics, True

# David - Higher privilege access (should be denied)
user:david, act:write, lib:math-basics, False
user:david, act:edit, lib:math-basics, False
user:david, act:delete, lib:math-basics, False
user:david, act:manage, lib:math-basics, False

# David - Cross-library access (should be denied)
user:david, act:read, lib:science-101, False

# David - Cross-scope access (should be denied)
user:david, act:read, org:OpenedX, False


# ===== UNAUTHORIZED USERS =====

# Unknown user - should be denied access (no role assignments)
user:unknown, act:read, lib:math-basics, False
user:unknown, act:manage, *, False
user:unknown, act:edit, org:OpenedX, False


# ===== ACTION INHERITANCE TESTS =====

# Test that manage implies edit, read, write, delete through g2 rules
user:alice, act:edit, *, True
user:alice, act:read, *, True
user:alice, act:write, *, True
user:alice, act:delete, *, True

user:bob, act:edit, org:OpenedX, True
user:bob, act:read, org:OpenedX, True
user:bob, act:write, org:OpenedX, True

user:eve, act:read, org:OpenedX, True
user:eve, act:write, org:OpenedX, True

user:carol, act:edit, course:course-v1:OpenedX+DemoX+CS101, True
user:carol, act:read, course:course-v1:OpenedX+DemoX+CS101, True
user:carol, act:write, course:course-v1:OpenedX+DemoX+CS101, True
